#!/usr/bin/env zsh
# Bot Army Ghostty Menu - Overlay menu for Bot Army commands
# Usage: ghostty calls this script via keybind

# Source the context plugin for current context
if [[ -f ~/.config/bot-army-shell/bot-army-context.zsh ]]; then
  source ~/.config/bot-army-shell/bot-army-context.zsh
fi

# Get current context for display
bot_context=$(bot_army_context_prompt 2>/dev/null)
current_dir=$(basename "$PWD" 2>/dev/null)
git_branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)

# Build header with context
header="Bot Army  ${bot_context:-} ${current_dir} (${git_branch})"

# Default NATS server for queries
NATS_SERVER="${NATS_SERVER:-localhost:4223}"

# Show current task from bridge
show_current_task() {
  echo "Fetching current task..."
  if command -v nats >/dev/null 2>&1; then
    local result
    result=$(nats request bridge.task.current '{}' --server "nats://$NATS_SERVER" --timeout 3s 2>/dev/null)
    if [[ -n "$result" ]]; then
      echo "$result" | head -30
    else
      echo "No current task or bridge not available"
    fi
  else
    echo "NATS CLI not available for direct query"
  fi
}

# Create new task via bridge
create_new_task() {
  echo "Opening task creation form..."
  if command -v nats >/dev/null 2>&1; then
    echo "Task creation form would open here"
    echo "Prompt: What task would you like to create?"
    read -r "task?Task description: "
    if [[ -n "$task" ]]; then
      nats request bridge.task.create "{\"description\":\"$task\"}" --server "nats://$NATS_SERVER" --timeout 3s 2>/dev/null
      echo "Task created: $task"
    fi
  else
    echo "NATS CLI not available"
  fi
}

# Context mode switching
switch_context() {
  local modes=("focused" "meeting" "casual" "DND")
  echo "Select context mode:"
  for i in {1..4}; do
    echo "  $i) ${modes[$i]}"
  done
  read -r "choice?Choice: "
  case $choice in
    1) target="focused" ;;
    2) target="meeting" ;;
    3) target="casual" ;;
    4) target="DND" ;;
    *) echo "Invalid choice"; return ;;
  esac
  echo "Switching to $target mode..."
  nats publish context.state.desired "{\"mode\":\"$target\"}" --server "nats://$NATS_SERVER" 2>/dev/null
  echo "Context mode set to $target"
}

# PARA search
para_search() {
  echo "PARA Search:"
  read -r "query?Search query: "
  if [[ -n "$query" ]]; then
    if command -v nats >/dev/null 2>&1; then
      echo "Searching PARA for: $query"
      nats request para.fs.search "{\"query\":\"$query\"}" --server "nats://$NATS_SERVER" --timeout 5s 2>/dev/null | head -20
    else
      echo "NATS CLI not available"
    fi
  fi
}

# Bot status display
bot_status() {
  echo "Bot Army Status:"
  echo ""
  if command -v nats >/dev/null 2>&1; then
    echo "NATS: Connected to $NATS_SERVER"
    echo ""
    echo "Bot Health:"
    # Try to get health from all bots
    nats sub system.health.> --server "nats://$NATS_SERVER" --one 2>/dev/null || echo "  (no health data available)"
  else
    echo "  NATS CLI not available"
  fi
  echo ""
  echo "Context Mode: $(cat /tmp/bot-army-context.sock 2>/dev/null | jq -r '.context_mode // \"unknown\"' 2>/dev/null || echo 'unknown')"
}

# Reflection
record_reflection() {
  echo "Recording reflection..."
  if command -v nats >/dev/null 2>&1; then
    nats request bridge.reflection.record '{"note":" reflection from ghostty menu"}' --server "nats://$NATS_SERVER" --timeout 3s 2>/dev/null
    echo "Reflection recorded"
  else
    echo "NATS CLI not available"
  fi
}

# Timer / focus mode
timer_mode() {
  echo "Timer / Focus Mode:"
  echo "  1) Start 25-minute focus timer"
  echo "  2) Start 5-minute break"
  echo "  3) Show active timer"
  echo "  4) Cancel timer"
  read -r "choice?Choice: "
  case $choice in
    1) echo "Starting focus timer..."; nats publish timer.focus.start '{"duration":1500}' --server "nats://$NATS_SERVER" 2>/dev/null ;;
    2) echo "Starting break timer..."; nats publish timer.break.start '{"duration":300}' --server "nats://$NATS_SERVER" 2>/dev/null ;;
    3) echo "Timer status: not implemented yet" ;;
    4) echo "Timer cancelled"; nats publish timer.cancel '{}' --server "nats://$NATS_SERVER" 2>/dev/null ;;
    *) echo "Invalid choice" ;;
  esac
}

# Quick command input
quick_command() {
  echo "Quick command input:"
  read -r "cmd?Enter command: "
  if [[ -n "$cmd" ]]; then
    echo "Executing: $cmd"
    # Would execute via NATS command handler
  fi
}

# Show full help
show_help() {
  cat << 'EOF'
Bot Army Ghostty Menu - Help

Quick Actions (Ctrl+B prefix):
  T    Show current task
  C    Create new task
  R    Record reflection
  P    PARA search
  S    Bot status

Context Modes:
  F    focused (deep work)
  M    meeting (discreet)
  C    casual (chat)
  D    DND (no notifications)

Navigation:
  M    Show this menu
  H    Show help
  Q    Quit

For full documentation:
  ~/.config/bot-army-shell/bot-army-ghostty-help.txt

NATS Server: $NATS_SERVER
EOF
}

# Show status in ghostty
show_status() {
  echo "Bot Army Status"
  echo "───────────────"
  echo "Context: $(bot_army_context_prompt 2>/dev/null || echo 'unknown')"
  echo "Bot: $(echo $PWD | grep -o 'bot_army_[^/]*' | sed 's/bot_army_//' || echo 'none')"
  echo "Git: $(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo 'none')"
}

# Create a simple menu using tui libraries if available, otherwise use fzf
show_menu() {
  if command -v fzf >/dev/null 2>&1; then
    show_menu_fzf
  elif command -v bemenu >/dev/null 2>&1; then
    show_menu_bemenu
  elif command -v rofi >/dev/null 2>&1; then
    show_menu_rofi
  else
    show_menu_terminal
  fi
}

show_menu_fzf() {
  local choice
  choice=$(echo "$menu_options" | fzf --height=100% --layout=reverse --prompt="Bot Army> " --ansi --header="$header")
  if [[ -n "$choice" ]]; then
    process_choice "$choice"
  fi
}

show_menu_bemenu() {
  local choice
  choice=$(echo "$menu_options" | bemenu -l 10 -p "Bot Army> " --ansi --parse-ephf)
  if [[ -n "$choice" ]]; then
    process_choice "$choice"
  fi
}

show_menu_rofi() {
  local choice
  choice=$(echo "$menu_options" | rofi -dmenu -p "Bot Army> " -theme-str "listview {lines: 10;}")
  if [[ -n "$choice" ]]; then
    process_choice "$choice"
  fi
}

show_menu_terminal() {
  clear
  echo "┌─────────────────────────────────────────────┐"
  echo "│ $header"
  echo "├─────────────────────────────────────────────┤"
  echo "$menu_options_ansi"
  echo "└─────────────────────────────────────────────┘"
  echo ""
  echo "Select an option (1-8) or press q to quit:"
  read -r choice
  case $choice in
    1) process_choice "Show current task" ;;
    2) process_choice "Create new task" ;;
    3) process_choice "Context switch" ;;
    4) process_choice "PARA search" ;;
    5) process_choice "Bot status" ;;
    6) process_choice "Reflection" ;;
    7) process_choice "Timer" ;;
    8) process_choice "Quick command" ;;
    q|Q) exit 0 ;;
    *) show_menu_terminal ;;
  esac
}

# Menu options
menu_options=$'[\x1b[36mM\x1b[0m] Show current task\n[\x1b[36mN\x1b[0m] Create new task\n[\x1b[36mC\x1b[0m] Context switch\n[\x1b[36mP\x1b[0m] PARA search\n[\x1b[36mB\x1b[0m] Bot status\n[\x1b[36mR\x1b[0m] Reflection\n[\x1b[36mT\x1b[0m] Timer / focus\n[\x1b[36mQ\x1b[0m] Quick command'

menu_options_ansi=$'  M - Show current task
  N - Create new task
  C - Context switch
  P - PARA search
  B - Bot status
  R - Reflection
  T - Timer / focus
  Q - Quick command'

process_choice() {
  local choice=$1
  case $choice in
    "Show current task"|"m"|"M")
      show_current_task
      ;;
    "Create new task"|"n"|"N")
      create_new_task
      ;;
    "Context switch"|"c"|"C")
      switch_context
      ;;
    "PARA search"|"p"|"P")
      para_search
      ;;
    "Bot status"|"b"|"B")
      bot_status
      ;;
    "Reflection"|"r"|"R")
      record_reflection
      ;;
    "Timer"|"t"|"T")
      timer_mode
      ;;
    "Quick command"|"q"|"Q")
      quick_command
      ;;
    "Show help"|"h"|"H")
      show_help
      ;;
    "Show status"|"s"|"S")
      show_status
      ;;
    *)
      echo "Unknown option: $choice"
      ;;
  esac
  echo ""
  echo "Press any key to return to menu..."
  read -r -n1 -t 1
  show_menu
}

# Run the menu
show_menu
